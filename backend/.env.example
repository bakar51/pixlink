# ──────────────────────────────────────────────────────────────────────────────
# PixLink — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS Core ──────────────────────────────────────────────────────────────────

# AWS region where your S3 bucket and DynamoDB table live
AWS_REGION=us-east-1

# S3 bucket name (the bucket must already exist)
AWS_BUCKET_NAME=your-s3-bucket-name

# DynamoDB table name (partition key: "code", type: String)
DYNAMODB_TABLE=pixlink-images

# ── AWS Credentials ───────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY.
# On EC2, leave these blank — the IAM Role attached to the instance
# provides credentials automatically via the instance metadata service (IMDS).
# If blank or omitted, the AWS SDK uses the IAM Role / credential chain.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Optional: CloudFront CDN ──────────────────────────────────────────────────
# If set, redirect URLs point to CloudFront instead of S3 directly.
# Example: https://d1abc123def456.cloudfront.net
# Leave blank to use S3 URLs.
CLOUDFRONT_BASE_URL=

# ── Server ────────────────────────────────────────────────────────────────────

# Express listen port (Nginx forwards port 80 → this port on EC2)
PORT=3000

# CORS — allowed frontend origin.
# Local dev: http://localhost:5173
# Production: http://YOUR_EC2_PUBLIC_IP  or  https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Window duration in milliseconds (default: 60 seconds)
RATE_LIMIT_WINDOW_MS=60000

# Max upload requests per IP per window (default: 20)
RATE_LIMIT_MAX=20
